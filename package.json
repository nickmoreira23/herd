{
  "name": "comecaai-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:workers": "opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ledger": "vitest run --config vitest.ledger.config.ts",
    "test:integration": "vitest run --config vitest.ledger.config.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:seed:ledger": "tsx prisma/seeds/seed-ledger.ts",
    "seed:recharge": "tsx scripts/seed-recharge-integration.ts",
    "seed:braintree": "tsx scripts/seed-braintree-integration.ts",
    "braintree:test-webhook": "tsx scripts/test-braintree-webhook.ts",
    "seed:connection": "tsx scripts/seed-member-connection.ts",
    "seed:braintree-connection": "tsx scripts/seed-member-connection.ts --slug=braintree",
    "seed:recharge-connection": "tsx scripts/seed-member-connection.ts --slug=recharge",
    "smoke:camada-2": "tsx scripts/validate-camada-2-smoke.ts",
    "smoke:camada-1": "tsx scripts/validate-camada-1-smoke.ts",
    "recharge:register-webhooks": "tsx scripts/register-recharge-webhooks.ts",
    "recharge:list-webhooks": "tsx scripts/list-recharge-webhooks.ts",
    "recharge:delete-webhook": "tsx scripts/delete-recharge-webhook.ts",
    "recharge:test-webhook": "tsx scripts/test-recharge-webhook.ts",
    "worker:domain-events": "tsx src/scripts/worker-domain-events.ts",
    "check:invariants": "tsx src/scripts/check-invariants.ts",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:enable-rls": "psql $DIRECT_URL -f scripts/enable-rls.sql",
    "gen:schemas": "tsx scripts/build-schemas.ts",
    "gen:mcp": "tsx scripts/build-mcp-manifest.ts",
    "gen:search-index": "tsx scripts/build-search-index.ts",
    "gen:xrefmap": "tsx scripts/build-xrefmap.ts",
    "gen:llms-txt": "tsx scripts/build-llms-txt.ts",
    "gen:glossary": "tsx scripts/build-glossary.ts",
    "gen:feature": "tsx .agents/skills/new-feature/scripts/run.ts",
    "mcp:dev": "tsx mcp/index.ts",
    "gen:all": "npm run gen:schemas && npm run gen:mcp && npm run gen:xrefmap && npm run gen:glossary && npm run gen:search-index && npm run gen:llms-txt",
    "validate:feature-yml": "tsx scripts/validate-feature-yml.ts",
    "validate:handbook-graph": "tsx scripts/validate-handbook-graph.ts",
    "validate:handbook": "npm run gen:all && git diff --exit-code schemas/ mcp/generated/ docs/handbook/_meta/xrefmap.yml && npm run validate:feature-yml && npm run validate:handbook-graph",
    "postinstall": "npx prisma generate && npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm run typecheck && npm test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@base-ui/react": "^1.3.0",
    "@dagrejs/dagre": "^3.0.0",
    "@deepgram/sdk": "^5.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@panva/hkdf": "^1.2.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@xyflow/react": "^12.10.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "braintree": "^3.37.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "fast-glob": "^3.3.3",
    "fluent-ffmpeg": "^2.1.3",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^5.0.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "preact": "^10.29.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.10.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/braintree": "^3.4.4",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@types/yaml": "^1.9.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "danger": "^11.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.1.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.95.0"
  }
}
