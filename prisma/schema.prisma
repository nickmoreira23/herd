generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================
// Subscription Tier Enums
// ========================

enum SubscriptionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubscriptionVisibility {
  PUBLIC
  REP_ONLY
  HIDDEN
}

enum BillingAnchor {
  SIGNUP_DATE
  FIRST_OF_MONTH
}

enum CreditIssuingTiming {
  ON_PAYMENT
  FIXED_DATE
}

enum CreditExpiryBehavior {
  FORFEIT
  CONVERT
  DONATE
}

enum TierChangeTiming {
  IMMEDIATE
  NEXT_CYCLE
}

enum CreditOnChange {
  CARRY_OVER
  RESET
  FORFEIT_EXCESS
}

enum PauseCreditBehavior {
  FROZEN
  FORFEIT
}

// ========================
// AI Agent Enums
// ========================

enum AgentStatus {
  DRAFT
  ACTIVE
  BETA
  DEPRECATED
}

enum AgentCategory {
  NUTRITION
  TRAINING
  RECOVERY
  COACHING
  ANALYTICS
  IMAGE_GENERATION
  VIDEO_GENERATION
  VOICE
  MULTIMODAL
}

enum ModelType {
  TEXT
  IMAGE
  VIDEO
  VOICE
}

enum KnowledgeItemType {
  DOCUMENT
  URL
  TEXT
  FAQ
  API_REFERENCE
}

enum KnowledgeItemStatus {
  DRAFT
  PROCESSING
  ACTIVE
  ERROR
  ARCHIVED
}

enum AgentToolAuthType {
  NONE
  API_KEY
  OAUTH2
  BEARER_TOKEN
  CUSTOM_HEADER
}

// ========================
// Landing Page Enums
// ========================

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ========================
// D2D Commission Enums
// ========================

enum OrgRoleType {
  REGIONAL_LEADER
  TEAM_LEAD
  REP
}

enum LedgerEntryType {
  EARNED
  HELD
  RELEASED
  CLAWED_BACK
  ADJUSTED
}

enum LedgerEntrySource {
  UPFRONT_BONUS
  RESIDUAL
  OVERRIDE
  ACCELERATOR_BONUS
  CLAWBACK
  MANUAL_ADJUSTMENT
}

enum PayoutCadence {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  TERMINATED
}

// ========================
// Partner Brand Enums
// ========================

enum PartnerBenefitType {
  PERCENTAGE_DISCOUNT
  FLAT_DISCOUNT
  FREE_TRIAL
  FREE_PRODUCT
  BOGO
  OTHER
}

enum PartnerCommissionType {
  PERCENTAGE
  FLAT
  CPA
  RECURRING
  HYBRID
}

enum PartnerStatus {
  RESEARCHED
  APPLIED
  APPROVED
  ACTIVE
  PAUSED
}

enum PartnerTierAccess {
  ALL
  BASIC
  PLUS
  PREMIUM
  ELITE
}

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  sku            String   @unique
  category       String   // SUPPLEMENT | APPAREL | ACCESSORY
  subCategory    String?
  redemptionType String   @default("Members Store") // "Members Store" | "Members Rate"
  retailPrice    Decimal  @db.Decimal(10, 2)
  memberPrice    Decimal  @db.Decimal(10, 2)
  costOfGoods    Decimal  @db.Decimal(10, 2)
  imageUrl       String?
  isActive       Boolean  @default(true)
  weightOz       Decimal? @db.Decimal(8, 2)
  tags           String[] // PostgreSQL native string array
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Extended product info (populated via URL scraping or manual entry)
  description          String?
  brand                String?
  sourceUrl            String?   // URL this product was scraped from
  flavor               String?   // Selected variant/flavor
  variants             Json?     // [{name: "Flavor", options: ["Blue Raz", "Watermelon"]}]
  servingSize          String?
  servingsPerContainer Int?
  ingredients          String?   // Plain text ingredient list
  supplementFacts      Json?     // [{name, amount, unit, dailyValue}]
  warnings             String?

  // Scrape lifecycle
  scrapeStatus      String?   // PENDING | PROCESSING | READY | ERROR
  scrapeError       String?
  lastScrapedAt     DateTime?
  rescrapeInterval  String?   // DAILY | WEEKLY | MONTHLY | null=off
  nextRescrapeAt    DateTime?

  images          ProductImage[]
  packageProducts PackageTierProduct[]
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Agent {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  key             String        @unique
  description     String?
  longDescription String?
  category        AgentCategory
  icon            String        @default("bot")
  iconUrl         String?
  status          AgentStatus   @default(DRAFT)
  sortOrder       Int           @default(0)

  // AI/LLM Configuration
  modelType       ModelType @default(TEXT)
  modelProvider   String?
  modelId         String?
  systemPrompt    String?
  temperature     Decimal?      @db.Decimal(3, 2)
  maxTokens       Int?

  // Image model config
  imageSize       String?   // "1024x1024", "1792x1024", "1024x1792"
  imageStyle      String?   // "natural", "vivid", "anime", etc.
  imageQuality    String?   // "standard", "hd"

  // Video model config
  videoDuration   Int?      // max duration in seconds
  videoResolution String?   // "720p", "1080p", "4k"
  videoAspectRatio String?  // "16:9", "9:16", "1:1"

  // Voice model config
  voiceId         String?   // provider-specific voice identifier
  voiceSpeed      Decimal?  @db.Decimal(3, 2) // 0.25 to 4.0
  voiceStability  Decimal?  @db.Decimal(3, 2) // 0.0 to 1.0

  // Rate Limiting & Cost
  dailyUsageLimit     Int?
  monthlyCostEstimate Decimal?  @db.Decimal(10, 2)
  avgTokensPerCall    Int?

  // Feature flags
  requiresMedia    Boolean @default(false)
  requiresHealth   Boolean @default(false)
  isConversational Boolean @default(false)

  // Response format
  responseFormat  String?  // "text" | "json" | "structured"

  // Metadata
  version   String   @default("1.0")
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tierAccess     AgentTierAccess[]
  knowledgeItems AgentKnowledgeItem[]
  skills         AgentSkill[]
  tools          AgentTool[]
}

model AgentTierAccess {
  id                     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId                String  @db.Uuid
  subscriptionTierId     String  @db.Uuid
  isEnabled              Boolean @default(true)
  dailyUsageLimitOverride Int?
  priorityAccess         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tier  SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([agentId, subscriptionTierId])
}

model AgentKnowledgeItem {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId       String              @db.Uuid
  type          KnowledgeItemType
  title         String
  content       String?
  sourceUrl     String?
  fileKey       String?
  fileMimeType  String?
  fileSizeBytes Int?
  status        KnowledgeItemStatus @default(ACTIVE)
  metadata      Json?
  priority      Int                 @default(0)
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, title])
}

model AgentSkill {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId         String   @db.Uuid
  name            String
  key             String
  description     String?
  promptFragment  String?
  isEnabled       Boolean  @default(true)
  requiresTools   String[]
  category        String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
}

model AgentTool {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId            String            @db.Uuid
  name               String
  key                String
  description        String?
  toolSchema         Json?
  endpointUrl        String?
  httpMethod         String            @default("POST")
  authType           AgentToolAuthType @default(NONE)
  authConfig         Json?
  headers            Json?
  timeoutMs          Int               @default(30000)
  isEnabled          Boolean           @default(true)
  rateLimitPerMinute Int?
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
}

model SubscriptionTier {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  slug                   String   @unique
  tagline                String?
  colorAccent            String   @default("#6B7280")
  iconUrl                String?
  description            String?
  highlightFeatures      String[]
  sortOrder              Int      @default(0)

  // Status & visibility
  status                 SubscriptionStatus     @default(ACTIVE)
  visibility             SubscriptionVisibility @default(PUBLIC)
  isActive               Boolean  @default(true) // DEPRECATED — use status; kept for migration
  isFeatured             Boolean  @default(false)

  // Pricing
  monthlyPrice           Decimal  @db.Decimal(10, 2)
  quarterlyPrice         Decimal  @db.Decimal(10, 2)
  annualPrice            Decimal  @db.Decimal(10, 2)
  quarterlyDisplay       Decimal? @db.Decimal(10, 2) // per-month equivalent shown to customer
  annualDisplay          Decimal? @db.Decimal(10, 2) // per-month equivalent shown to customer
  setupFee               Decimal  @default(0) @db.Decimal(10, 2)
  trialDays              Int      @default(0)
  billingAnchor          BillingAnchor @default(SIGNUP_DATE)

  // Credits
  monthlyCredits         Decimal  @db.Decimal(10, 2)
  creditExpirationDays   Int      @default(60)
  creditIssuing          CreditIssuingTiming @default(ON_PAYMENT)
  rolloverMonths         Int      @default(0)  // 0 = no rollover
  rolloverCap            Decimal? @db.Decimal(10, 2) // null = uncapped
  creditExpiry           CreditExpiryBehavior @default(FORFEIT)
  annualBonusCredits     Decimal  @default(0) @db.Decimal(10, 2)
  referralCreditAmt      Decimal  @default(0) @db.Decimal(10, 2)

  // Partner & apparel (existing)
  partnerDiscountPercent Decimal  @db.Decimal(5, 2)
  includedAIFeatures     String[]
  apparelCadence         String   // NONE | QUARTERLY | MONTHLY
  apparelBudget          Decimal? @db.Decimal(10, 2)

  // Access controls
  maxMembers             Int?     // null = unlimited
  geoRestriction         String[] // ISO country codes, empty = all
  minimumAge             Int?
  inviteOnly             Boolean  @default(false)
  repChannelOnly         Boolean  @default(false)

  // Tier movement
  upgradeToTierIds       String[] // cuid references to eligible upgrade targets
  downgradeToTierIds     String[] // cuid references to eligible downgrade targets
  upgradeTiming          TierChangeTiming @default(IMMEDIATE)
  downgradeTiming        TierChangeTiming @default(NEXT_CYCLE)
  creditOnUpgrade        CreditOnChange   @default(CARRY_OVER)
  creditOnDowngrade      CreditOnChange   @default(FORFEIT_EXCESS)

  // Cancellation & retention
  minimumCommitMonths    Int      @default(1)
  pauseAllowed           Boolean  @default(false)
  pauseMaxMonths         Int      @default(0)
  pauseCreditBehavior    PauseCreditBehavior @default(FROZEN)
  winbackDays            Int      @default(0)   // 0 = no win-back
  winbackBonusCredits    Decimal  @default(0) @db.Decimal(10, 2)
  exitSurveyRequired     Boolean  @default(false)

  // Value pillar JSON configs
  agentConfig            Json?    // Tab 7: AI agent toggles
  communityConfig        Json?    // Tab 9: community benefits toggles
  perksConfig            Json?    // Tab 10: perks toggles + sub-config

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  commissionTierRates  CommissionTierRate[]
  commissionPlanRates  CommissionPlanRate[]
  partnerAssignments   PartnerTierAssignment[]
  financialSnapshots   FinancialSnapshot[]
  redemptionRules      SubscriptionRedemptionRule[]
  pricingSnapshots     TierPricingSnapshot[]
  agentAccess          AgentTierAccess[]
  perkAssignments      PerkTierAssignment[]
  communityAssignments CommunityBenefitTierAssignment[]
  integrationMappings  IntegrationTierMapping[]
  packageVariants      PackageTierVariant[]
}

// @deprecated — replaced by CommissionPlan. Kept for migration.
model CommissionStructure {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  isActive           Boolean  @default(false)
  clawbackWindowDays Int      @default(60)
  residualPercent    Decimal  @db.Decimal(5, 2)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tierRates CommissionTierRate[]
}

// @deprecated — replaced by CommissionPlanRate. Kept for migration.
model CommissionTierRate {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commissionStructureId String   @db.Uuid
  subscriptionTierId    String   @db.Uuid
  flatBonusAmount       Decimal  @db.Decimal(10, 2)
  acceleratorThreshold  Decimal? @db.Decimal(5, 2)
  acceleratorMultiplier Decimal? @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  commissionStructure CommissionStructure @relation(fields: [commissionStructureId], references: [id], onDelete: Cascade)
  subscriptionTier    SubscriptionTier    @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([commissionStructureId, subscriptionTierId])
}

model PartnerBrand {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  key                      String   @unique
  logoUrl                  String?
  heroImageUrl             String?
  discountDescription      String?
  tagline                  String?
  description              String?  // 2-3 sentence rich description
  websiteUrl               String?
  isActive                 Boolean  @default(true) // DEPRECATED — use status; kept for migration
  kickbackType             String   // NONE | PERCENT_OF_SALE | FLAT_PER_REFERRAL | FLAT_PER_MONTH
  kickbackValue            Decimal? @db.Decimal(10, 2)
  category                 String

  // Audience benefit
  audienceBenefit          String?  // e.g. "20% off your first order"
  benefitType              PartnerBenefitType?

  // Affiliate program details
  affiliateSignupUrl       String?
  affiliateLinkPlaceholder String?  // filled after manual signup
  affiliateNetwork         String?  // e.g. "Impact", "ShareASale", "In-house"
  commissionRate           String?  // e.g. "15%", "$20 flat", "Up to 50%"
  commissionType           PartnerCommissionType?
  cookieDuration           String?  // e.g. "30 days", "Lifetime"

  // Status & access
  status                   PartnerStatus     @default(ACTIVE)
  tierAccess               PartnerTierAccess @default(ALL)

  // Scraper metadata
  scrapedAt                DateTime?
  notes                    String?

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tierAssignments PartnerTierAssignment[]
}

model PartnerTierAssignment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerBrandId     String   @db.Uuid
  subscriptionTierId String   @db.Uuid
  discountPercent    Decimal  @db.Decimal(5, 2)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  partner PartnerBrand     @relation(fields: [partnerBrandId], references: [id], onDelete: Cascade)
  tier    SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([partnerBrandId, subscriptionTierId])
}

model FinancialSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String?  @db.Uuid
  billingCycle       String?  // MONTHLY | QUARTERLY | ANNUAL
  scenarioName       String?
  color              String?  // hex color for visual identification
  assumptions        Json
  results            Json
  createdBy          String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptionTier SubscriptionTier? @relation(fields: [subscriptionTierId], references: [id])
}

model TierPricingSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String   @db.Uuid
  monthlyPrice       Decimal  @db.Decimal(10, 2)
  quarterlyPrice     Decimal? @db.Decimal(10, 2)
  annualPrice        Decimal? @db.Decimal(10, 2)
  changedBy          String?
  reason             String?
  createdAt          DateTime @default(now())

  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)
}

model OpexCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  icon        String?  // lucide icon name
  color       String   @default("#6B7280") // hex color
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items OpexItem[]
}

model OpexMilestoneLevel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberCount Int      @unique
  label       String   // e.g. "Pre-Launch", "1k", "5k"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OpexItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String   @db.Uuid
  name        String
  description String?
  vendor      String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    OpexCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  milestones  OpexMilestone[]
}

model OpexMilestone {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId         String   @db.Uuid
  memberCount    Int      // e.g. 0, 1000, 5000, 10000
  monthlyCost    Decimal  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  item OpexItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, memberCount])
}

model SubscriptionRedemptionRule {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String   @db.Uuid
  redemptionType     String   // MEMBERS_STORE | MEMBERS_RATE
  discountPercent    Int      // 0–100
  scopeType          String   // CATEGORY | SUB_CATEGORY | SKU
  scopeValue         String   // category name, sub-category name, or product SKU
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([subscriptionTierId, redemptionType, scopeType, scopeValue])
}

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  type          String   @default("office") // headquarters, office, store, warehouse, other
  street        String?
  street2       String?
  city          String?
  state         String?
  zip           String?
  country       String?
  phone         String?
  email         String?
  isHeadquarters Boolean @default(false)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ========================
// D2D Commission Models
// ========================

model D2DPartner {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  logoUrl      String?
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orgNodes   OrgNode[]
  agreements PartnerAgreement[]
}

model OrgNode {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  d2dPartnerId String      @db.Uuid
  parentId     String?     @db.Uuid
  name         String
  roleType     OrgRoleType
  email        String?
  phone        String?
  isActive     Boolean     @default(true)
  hireDate     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  partner       D2DPartner  @relation(fields: [d2dPartnerId], references: [id], onDelete: Cascade)
  parent        OrgNode?    @relation("OrgHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      OrgNode[]   @relation("OrgHierarchy")
  ledgerEntries CommissionLedgerEntry[]

  @@index([d2dPartnerId])
  @@index([parentId])
}

model CommissionPlan {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  version         Int       @default(1)
  isActive        Boolean   @default(false)
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  residualPercent Decimal   @db.Decimal(5, 2)
  notes           String?

  legacyStructureId String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planRates        CommissionPlanRate[]
  overrideRules    OverrideRule[]
  performanceTiers PerformanceTier[]
  agreements       PartnerAgreement[]

  @@unique([name, version])
}

model CommissionPlanRate {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commissionPlanId   String      @db.Uuid
  subscriptionTierId String      @db.Uuid
  roleType           OrgRoleType
  upfrontBonus       Decimal     @db.Decimal(10, 2)
  residualPercent    Decimal     @db.Decimal(5, 2)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  commissionPlan   CommissionPlan   @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)
  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([commissionPlanId, subscriptionTierId, roleType])
}

model OverrideRule {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commissionPlanId String      @db.Uuid
  roleType         OrgRoleType
  overrideType     String      // FLAT | PERCENT_OF_BONUS | PERCENT_OF_REVENUE
  overrideValue    Decimal     @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  commissionPlan CommissionPlan @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)

  @@unique([commissionPlanId, roleType])
}

model PerformanceTier {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commissionPlanId String  @db.Uuid
  label            String
  minSales         Int
  maxSales         Int?
  bonusMultiplier  Decimal @db.Decimal(5, 2)
  bonusFlat        Decimal @default(0) @db.Decimal(10, 2)
  sortOrder        Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  commissionPlan CommissionPlan @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)

  @@index([commissionPlanId])
}

model ClawbackRule {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agreementId     String   @db.Uuid
  windowDays      Int
  clawbackPercent Decimal  @db.Decimal(5, 2)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agreement PartnerAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@unique([agreementId, windowDays])
}

model PartnerAgreement {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  d2dPartnerId     String          @db.Uuid
  commissionPlanId String          @db.Uuid
  name             String
  status           AgreementStatus @default(DRAFT)
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  payoutCadence    PayoutCadence   @default(MONTHLY)
  holdPeriodDays   Int             @default(30)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

