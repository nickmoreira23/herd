model FinancialSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String?  @db.Uuid
  billingCycle       String? // MONTHLY | QUARTERLY | ANNUAL
  scenarioName       String?
  color              String? // hex color for visual identification
  assumptions        Json
  results            Json
  createdBy          String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptionTier SubscriptionTier? @relation(fields: [subscriptionTierId], references: [id])
}

model TierPricingSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String   @db.Uuid
  // Per-month rates at the time of snapshot (see SubscriptionTier.biannualPrice
  // and .annualPrice for semantics — the customer prepays rate × cycle).
  monthlyPrice       Decimal  @db.Decimal(10, 2)
  biannualPrice      Decimal? @db.Decimal(10, 2)
  annualPrice        Decimal? @db.Decimal(10, 2)
  changedBy          String?
  reason             String?
  createdAt          DateTime @default(now())

  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)
}

model OpexCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  icon        String? // lucide icon name
  color       String   @default("#6B7280") // hex color
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items OpexItem[]
}

model OpexMilestoneLevel {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberCount Int      @unique
  label       String // e.g. "Pre-Launch", "1k", "5k"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OpexItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String   @db.Uuid
  name        String
  description String?
  vendor      String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   OpexCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  milestones OpexMilestone[]
}

model OpexMilestone {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId      String   @db.Uuid
  memberCount Int // e.g. 0, 1000, 5000, 10000
  monthlyCost Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item OpexItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, memberCount])
}

model SubscriptionRedemptionRule {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionTierId String   @db.Uuid
  redemptionType     String // MEMBERS_STORE | MEMBERS_RATE
  discountPercent    Int // 0–100
  scopeType          String // CATEGORY | SUB_CATEGORY | SKU
  scopeValue         String // category name, sub-category name, or product SKU
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([subscriptionTierId, redemptionType, scopeType, scopeValue])
}

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  type           String   @default("office") // headquarters, office, store, warehouse, other
  street         String?
  street2        String?
  city           String?
  state          String?
  zip            String?
  country        String?
  phone          String?
  email          String?
  isHeadquarters Boolean  @default(false)
  isActive       Boolean  @default(true)
  notes          String?
  source         RecordSource @default(MANUAL)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant            Organization           @relation("LocationTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  organizationLinks OrganizationLocation[]

  @@index([tenantId])
}

// ADR-002 Fatia 1a — proveniência de registros de bloco.
enum RecordSource {
  MANUAL
  ORGANIZATION
  INTEGRATION
  SYSTEM

  @@map("record_source")
}

// ADR-002 Fatia 1a — consumo curado: junção Organization⊆bloco-locations (molde *TierAssignment).
// tenantId é escalar (= organizationId em V1); scoping via Extension/TENANT_SCOPED_MODELS + RLS.
// A FK tenant_id→organizations agora é modelada como relation "OrgLocationTenant" (R&P Fase 2):
// alinha com as demais tabelas tenant-scoped e elimina o drift schema↔DB que o migrate dev acusava.
// D6: deletar Location (mestre) OU Organization (consumidor) → vínculo cai (Cascade).
// Desvincular (deletar este vínculo) NÃO deleta o Location — o catálogo-mestre sobrevive.
model OrganizationLocation {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  locationId     String   @map("location_id") @db.Uuid
  isEnabled      Boolean  @default(true) @map("is_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation("OrgLocationConsumer", fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Organization @relation("OrgLocationTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, locationId])
  @@index([tenantId])
  @@index([locationId])
  @@map("organization_location")
}

// ========================
// D2D Commission Models
// ========================

/// @deprecated since Phase 1, Etapa 1.2 of the Marketplace+Opportunities project.
/// This single-table ledger is frozen — no new writes after this point.
/// All new financial movements go through the double-entry ledger
/// (models Account / JournalEntry / JournalLine in this same schema).
/// See docs/discovery/HERD_DISCOVERY_REPORT.md, section 9, for the rationale.
/// Data migration from this model to the new ledger is deferred to a later phase.

// ========================
// Foundation: Perks
// ========================

enum PerkStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Perk {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  key              String     @unique
  description      String?
  longDescription  String?
  icon             String     @default("gift")
  status           PerkStatus @default(DRAFT)
  hasSubConfig     Boolean    @default(false)
  subConfigLabel   String? // e.g. "Amount ($)", "Tier Level"
  subConfigType    String? // "number", "select"
  subConfigOptions String[] // e.g. ["standard", "priority", "vip"]
  sortOrder        Int        @default(0)
  tags             String[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  tierAssignments PerkTierAssignment[]
}

model PerkTierAssignment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perkId             String   @db.Uuid
  subscriptionTierId String   @db.Uuid
  isEnabled          Boolean  @default(true)
  configValue        String? // stores sub-config value (e.g. "25", "vip")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  perk Perk             @relation(fields: [perkId], references: [id], onDelete: Cascade)
  tier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([perkId, subscriptionTierId])
}

// ========================
// Foundation: Community
// ========================

enum CommunityBenefitStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model CommunityBenefit {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  key             String                 @unique
  description     String?
  longDescription String?
  icon            String                 @default("users")
  status          CommunityBenefitStatus @default(DRAFT)
  platform        String? // e.g. "discord", "zoom", "forum", "in-person"
  accessUrl       String? // link to the community resource
  sortOrder       Int                    @default(0)
  tags            String[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tierAssignments CommunityBenefitTierAssignment[]
}

model CommunityBenefitTierAssignment {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityBenefitId String   @db.Uuid
  subscriptionTierId String   @db.Uuid
  isEnabled          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  communityBenefit CommunityBenefit @relation(fields: [communityBenefitId], references: [id], onDelete: Cascade)
  tier             SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([communityBenefitId, subscriptionTierId])
}

model Document {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  category    String // CONTRACT, TERMS, PRESENTATION, POLICY, OTHER
  fileName    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  isActive    Boolean  @default(true)
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========================
// Knowledge Base
// ========================

enum KnowledgeDocumentStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum KnowledgeFolderType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
}

model KnowledgeFolder {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  color       String? // optional color for folder icon (hex)
  folderType  KnowledgeFolderType @default(DOCUMENT)
  parentId    String?             @db.Uuid
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  parent   KnowledgeFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
