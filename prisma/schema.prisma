  @@index([routineId])
  @@index([agentId])
  @@map("routine_steps")
}

// ============================================================
// Double-entry ledger — Phase 1, Etapa 1.2
// All monetary movements in the new system flow through these tables.
// Invariant: for every JournalEntry, sum(D) = sum(C) per currency.
// ============================================================

enum AccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
  EQUITY
}

enum AccountOwnerKind {
  PLATFORM
  PROFILE
  EXTERNAL
}

enum JournalLineDirection {
  D
  C
}

enum JournalEntrySourceKind {
  TRANSACTION
  COMMISSION
  REFUND
  MANUAL_ADJUSTMENT
  SEED
  REVERSAL
}

model Account {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String           @unique
  name        String
  accountType AccountType
  ownerKind   AccountOwnerKind
  ownerId     String?          @db.Uuid
  currency    String           @db.Char(3)
  metadata    Json             @default("{}")
  archivedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  journalLines JournalLine[]

  @@index([ownerKind, ownerId])
  @@index([accountType])
  @@index([currency])
  @@map("accounts")
}

model JournalEntry {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceKind     JournalEntrySourceKind
  sourceId       String                 @db.Uuid
  idempotencyKey String?                @unique
  description    String?
  postedAt       DateTime               @default(now())
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())

  lines JournalLine[]

  @@index([sourceKind, sourceId])
  @@index([postedAt])
  @@map("journal_entries")
}

model JournalLine {
  id             BigInt               @id @default(autoincrement())
  journalEntryId String               @db.Uuid
  accountId      String               @db.Uuid
  direction      JournalLineDirection
  amountCents    BigInt
  currency       String               @db.Char(3)
  createdAt      DateTime             @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_lines")
}

// ============================================================
// Domain events outbox — Phase 1, Etapa 1.8
// Cross-bounded-context communication via outbox pattern. Events are
// emitted within the same transaction that produces the domain change,
// then drained by a worker (npm run worker:domain-events).
// ============================================================

model DomainEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aggregateType  String
  aggregateId    String    @db.Uuid
  eventType      String
  payload        Json      @default("{}")
  idempotencyKey String?   @unique
  occurredAt     DateTime
  createdAt      DateTime  @default(now())
  processedAt    DateTime?
  attempts       Int       @default(0)
  lastError      String?
  nextAttemptAt  DateTime?

  @@index([processedAt, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@map("domain_events")
}

/// Inbound-webhook deduplication ledger (Sub-etapa 6).
///
/// One row per `(provider, event_id)` pair we've acknowledged. Lookups happen
/// at the webhook ingress, BEFORE the work is queued in the outbox: if the
/// pair already exists, the handler returns 200 immediately without re-emitting
/// a domain event, so retries from the provider don't multiply downstream work.
///
/// Platform-wide (no `tenant_id`, no RLS) — the dedup key is provider-scoped
/// and tenants don't share `event_id` namespaces in practice. The same key
/// can't legitimately appear under two tenants from the same provider.
///
/// `expires_at = received_at + 30 days` (column default). Cleanup is tech
/// debt — there's no scheduled DELETE today. Trigger to add: row count >
/// ~10 million OR write contention measurable on the unique index.
model WebhookDedup {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider   String
  eventId    String   @map("event_id")
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  expiresAt  DateTime @default(dbgenerated("(now() + '30 days'::interval)")) @map("expires_at") @db.Timestamptz(6)

  @@unique([provider, eventId], map: "webhook_dedup_provider_event_id_key")
  @@index([expiresAt], map: "webhook_dedup_expires_at_idx")
  @@map("webhook_dedup")
}

// ========================
// Payment Provider Layer (Sub-etapa 9)
// ========================
//
// 11 tables modeling the canonical billing surface. All tenant-scoped
// (RLS strict policy + tenant_id NOT NULL + FK to Organization).
// providerData JSONB preserves the raw provider payload.

enum ChargeStatus {
  QUEUED
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  SKIPPED
  CANCELLED
}

/// Catalog of payment providers connected per tenant (e.g. `recharge`).
/// `provider_id` FK on every other billing table points here.
model PaymentProvider {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  slug         String
  name         String
  category     String // BILLING | PAYMENT
  providerData Json     @default("{}") @map("provider_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Organization @relation("PaymentProviderTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  billingCustomers BillingCustomer[]
  paymentMethods   PaymentMethod[]
  subscriptions    Subscription[]
  charges          Charge[]
  invoices         Invoice[]
  refunds          Refund[]
  dunningAttempts  DunningAttempt[]
  portalSessions   PortalSession[]
  billingEvents    BillingEvent[]

  @@unique([tenantId, slug], map: "payment_providers_tenant_slug_unique")
  @@index([tenantId], map: "payment_providers_tenant_idx")
  @@map("payment_providers")
}

/// Customer record mirrored from the provider. `memberConnectionId` links
/// the customer back to the platform's member (nullable — provider may
/// know the customer before the member is connected).
model BillingCustomer {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  providerId         String   @map("provider_id") @db.Uuid
  externalId         String   @map("external_id")
  email              String?
  name               String?
  memberConnectionId String?  @map("member_connection_id") @db.Uuid
  providerData       Json     @default("{}") @map("provider_data")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Organization      @relation("BillingCustomerTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider         PaymentProvider   @relation(fields: [providerId], references: [id], onDelete: Restrict)
  memberConnection MemberConnection? @relation("BillingCustomerMemberConnection", fields: [memberConnectionId], references: [id], onDelete: SetNull)

  paymentMethods PaymentMethod[]
  subscriptions  Subscription[]
  charges        Charge[]
  portalSessions PortalSession[]

  @@unique([providerId, externalId], map: "billing_customers_provider_external_unique")
  @@index([tenantId], map: "billing_customers_tenant_idx")
  @@index([memberConnectionId], map: "billing_customers_member_connection_idx")
  @@map("billing_customers")
}

/// Stored payment instrument (card/paypal/…). Tokenized at the provider
/// — only last4/brand surfaced locally.
model PaymentMethod {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  providerId   String   @map("provider_id") @db.Uuid
  externalId   String   @map("external_id")
  customerId   String   @map("customer_id") @db.Uuid
  type         String
  last4        String?
  brand        String?
  isDefault    Boolean  @default(false) @map("is_default")
  providerData Json     @default("{}") @map("provider_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Organization    @relation("PaymentMethodTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  customer BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  subscriptions Subscription[]
  charges       Charge[]

  @@unique([providerId, externalId], map: "payment_methods_provider_external_unique")
  @@index([tenantId], map: "payment_methods_tenant_idx")
  @@index([customerId], map: "payment_methods_customer_idx")
  @@map("payment_methods")
}

/// Active subscription record (cliente → plano). `tierId` links to the
/// platform `SubscriptionTier` catalog when the provider plan maps to a
/// known tier (nullable — provider plan may not be in the catalog).
model Subscription {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  providerId      String    @map("provider_id") @db.Uuid
  externalId      String    @map("external_id")
  customerId      String    @map("customer_id") @db.Uuid
  paymentMethodId String?   @map("payment_method_id") @db.Uuid
  tierId          String?   @map("tier_id") @db.Uuid
  status          String
  nextChargeAt    DateTime? @map("next_charge_at") @db.Timestamptz(6)
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz(6)
  providerData    Json      @default("{}") @map("provider_data")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Organization      @relation("SubscriptionTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider      PaymentProvider   @relation(fields: [providerId], references: [id], onDelete: Restrict)
  customer      BillingCustomer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?    @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  tier          SubscriptionTier? @relation("SubscriptionTier", fields: [tierId], references: [id], onDelete: SetNull)

  lineItems ChargeLineItem[]

  @@unique([providerId, externalId], map: "subscriptions_provider_external_unique")
  @@index([tenantId], map: "subscriptions_tenant_idx")
  @@index([customerId], map: "subscriptions_customer_idx")
  @@index([tierId], map: "subscriptions_tier_idx")
  @@index([status], map: "subscriptions_status_idx")
  @@map("subscriptions")
}

/// Single charge event from the provider. Composite charges (one customer,
/// multiple subscriptions) are split via `ChargeLineItem`.
model Charge {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  providerId      String       @map("provider_id") @db.Uuid
  externalId      String       @map("external_id")
  customerId      String       @map("customer_id") @db.Uuid
  paymentMethodId String?      @map("payment_method_id") @db.Uuid
  status          ChargeStatus
  amountCents     Int          @map("amount_cents")
  currency        String       @default("USD")
  processedAt     DateTime?    @map("processed_at") @db.Timestamptz(6)
  failedAt        DateTime?    @map("failed_at") @db.Timestamptz(6)
  failureReason   String?      @map("failure_reason")
  providerData    Json         @default("{}") @map("provider_data")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Organization    @relation("ChargeTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider      PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  customer      BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  lineItems       ChargeLineItem[]
  invoices        Invoice[]
  refunds         Refund[]
  dunningAttempts DunningAttempt[]

  @@unique([providerId, externalId], map: "charges_provider_external_unique")
  @@index([tenantId], map: "charges_tenant_idx")
  @@index([customerId], map: "charges_customer_idx")
  @@index([status], map: "charges_status_idx")
  @@index([processedAt], map: "charges_processed_at_idx")
  @@map("charges")
}

/// Junction N:N between Charge and Subscription. Splits a composite
/// charge into per-subscription portions. No `external_id`/`provider_id`
/// of its own — derives from the parent charge.
model ChargeLineItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  chargeId       String   @map("charge_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  amountCents    Int      @map("amount_cents")
  providerData   Json     @default("{}") @map("provider_data")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Organization @relation("ChargeLineItemTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  charge       Charge       @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([chargeId, subscriptionId], map: "charge_line_items_charge_subscription_unique")
  @@index([tenantId], map: "charge_line_items_tenant_idx")
  @@index([chargeId], map: "charge_line_items_charge_idx")
  @@index([subscriptionId], map: "charge_line_items_subscription_idx")
  @@map("charge_line_items")
}

/// Invoice document for a charge. Some providers issue invoices
/// independent of charge — captured here as `provider_data` + nullable
/// fields rather than splitting the model.
model Invoice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  providerId    String    @map("provider_id") @db.Uuid
  externalId    String    @map("external_id")
  chargeId      String    @map("charge_id") @db.Uuid
  invoiceNumber String?   @map("invoice_number")
  pdfUrl        String?   @map("pdf_url")
  issuedAt      DateTime? @map("issued_at") @db.Timestamptz(6)
  providerData  Json      @default("{}") @map("provider_data")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Organization    @relation("InvoiceTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  charge   Charge          @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId], map: "invoices_provider_external_unique")
  @@index([tenantId], map: "invoices_tenant_idx")
  @@index([chargeId], map: "invoices_charge_idx")
  @@map("invoices")
}

/// Refund record (full or partial). For partial refunds, multiple rows
/// can attach to the same charge.
model Refund {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  providerId   String    @map("provider_id") @db.Uuid
  externalId   String    @map("external_id")
  chargeId     String    @map("charge_id") @db.Uuid
  amountCents  Int       @map("amount_cents")
  reason       String?
  refundedAt   DateTime? @map("refunded_at") @db.Timestamptz(6)
  providerData Json      @default("{}") @map("provider_data")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Organization    @relation("RefundTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  charge   Charge          @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId], map: "refunds_provider_external_unique")
  @@index([tenantId], map: "refunds_tenant_idx")
  @@index([chargeId], map: "refunds_charge_idx")
  @@map("refunds")
}

/// Retry attempt for a failed charge (provider-driven dunning flow).
/// One row per attempt; `outcome` records the resolution.
model DunningAttempt {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  providerId    String   @map("provider_id") @db.Uuid
  externalId    String   @map("external_id")
  chargeId      String   @map("charge_id") @db.Uuid
  attemptNumber Int      @map("attempt_number")
  attemptedAt   DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)
  outcome       String // retry_succeeded | retry_failed | abandoned
  providerData  Json     @default("{}") @map("provider_data")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Organization    @relation("DunningAttemptTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  charge   Charge          @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId], map: "dunning_attempts_provider_external_unique")
  @@index([tenantId], map: "dunning_attempts_tenant_idx")
  @@index([chargeId], map: "dunning_attempts_charge_idx")
  @@map("dunning_attempts")
}

/// Short-lived customer-portal session URL surfaced by the provider.
/// Used to redirect customers to the provider's hosted billing UI.
model PortalSession {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  providerId   String   @map("provider_id") @db.Uuid
  externalId   String   @map("external_id")
  customerId   String   @map("customer_id") @db.Uuid
  sessionUrl   String   @map("session_url")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  providerData Json     @default("{}") @map("provider_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Organization    @relation("PortalSessionTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  customer BillingCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalId], map: "portal_sessions_provider_external_unique")
  @@index([tenantId], map: "portal_sessions_tenant_idx")
  @@index([customerId], map: "portal_sessions_customer_idx")
  @@map("portal_sessions")
}

/// Internal audit log for billing-domain state transitions. Distinct from
/// `domain_events` (cross-context outbox) and `IntegrationWebhookEvent`
/// (provider-raw webhook log). This table captures the BILLING-domain
/// view: `subscription.status_changed`, `charge.refunded`, etc.
model BillingEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  eventType  String   @map("event_type")
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Organization    @relation("BillingEventTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  provider PaymentProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([tenantId], map: "billing_events_tenant_idx")
  @@index([entityType, entityId], map: "billing_events_entity_idx")
  @@index([eventType], map: "billing_events_event_type_idx")
  @@index([createdAt], map: "billing_events_created_at_idx")
  @@map("billing_events")
}

// ========================
// Audit Log (Sub-etapa 25)
// Strict tenant-scoped, mirrors BillingEvent molde (tenant_id NOT NULL + RLS
// tenant_isolation, no herd_app_full_access). Append-only audit trail of
// sensitive actions (invitations, departments, locations, org-chart).
// ========================

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  actorProfileId String?  @map("actor_profile_id") @db.Uuid
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Organization    @relation("AuditLogTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  actor  NetworkProfile? @relation("AuditLogActor", fields: [actorProfileId], references: [id], onDelete: SetNull)

  @@index([tenantId], map: "audit_logs_tenant_idx")
  @@index([resourceType, resourceId], map: "audit_logs_resource_idx")
  @@index([action], map: "audit_logs_action_idx")
  @@index([createdAt], map: "audit_logs_created_at_idx")
  @@index([actorProfileId], map: "audit_logs_actor_idx")
  @@map("audit_logs")
}

// ========================
// Organization Enums (Sub-etapa 18 — Fase 4 foundation)
// ========================

enum OrgSize {
  SOLO
  SMALL
  MID
  LARGE
  ENTERPRISE

  @@map("org_size")
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
  DELETED

  @@map("org_status")
}

enum AssetType {
  LOGO_LIGHT
  LOGO_DARK
  LOGO_SQUARE
  FAVICON
  OG_IMAGE

  @@map("asset_type")
}

// Sub-etapa 20 — Membership enums

enum MembershipStatus {
  ACTIVE
  SUSPENDED
  INVITED
  REMOVED

  @@map("membership_status")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  DEPARTMENT_HEAD
  DEPARTMENT_MANAGER
  DEPARTMENT_MEMBER

  @@map("member_role")
}

enum RoleScopeType {
  ORG
  DEPARTMENT

  @@map("role_scope_type")
}

// R&P Fase 6a — a RolePermission row either grants or denies its slot. Deny is the
// per-org override mechanism (subtract a system grant for one org); processed in the
// loader from Fase 6b. Default grant keeps all existing rows behavior-identical.
enum RoleEffect {
  grant
  deny

  @@map("role_effect")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED

  @@map("invitation_status")
}
