// Hybrid (R&P Fase 5, SOMA model): a row is EITHER a system role (`role` enum set,
// `roleId` NULL) OR a custom per-org role assignment (`roleId` FK set, `role` NULL).
// A member may hold one system ORG role + N custom roles at once (additive). The
// exactly-one(role, roleId) invariant is a raw-SQL CHECK (Prisma can't model it).
model MembershipRole {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId   String         @map("member_id") @db.Uuid
  role       MemberRole?
  roleId     String?        @map("role_id") @db.Uuid
  scopeType  RoleScopeType  @default(ORG) @map("scope_type")
  scopeId    String?        @map("scope_id") @db.Uuid
  assignedAt DateTime       @default(now()) @map("assigned_at")

  member     OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  customRole Role?              @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([roleId])
  @@map("membership_roles")
}

// Global role→permission matrix (Roles & Permissions V3.1). One row per grant.
// During V3.1 this table is SEEDED from the hardcoded ROLE_PERMISSIONS and
// proven equal to it by a parity test — nothing reads from it yet (can() still
// reads the constant). GLOBAL: no tenantId, not in TENANT_SCOPED_MODELS.
// resource/action are strings validated by the typed seed + parity test (the
// source of truth stays the ResourceType/ActionType unions in code).
// Hybrid grant (R&P Fase 3): exactly one of (role, roleId) is set — enforced by a
// CHECK constraint added in raw SQL (Prisma does not model CHECKs). `role` = system
// role (enum); `roleId` = custom Role. `tenantId` NULL = global grant (the 97 system
// rows + any global custom), set = per-org override. The composite unique uses
// NULLS NOT DISTINCT so global rows (tenantId/roleId NULL) still dedup correctly.
model RolePermission {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role      MemberRole?
  roleId    String?       @map("role_id") @db.Uuid
  tenantId  String?       @map("tenant_id") @db.Uuid
  resource  String
  action    String
  scopeType RoleScopeType @default(ORG) @map("scope_type")
  // R&P Fase 6a — grant | deny. Default grant (the existing rows backfill to grant).
  // Deny processing in the loader + the admin floor land in Fase 6b; effect is inert here.
  effect    RoleEffect    @default(grant)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  customRole Role?         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant     Organization? @relation("RolePermissionTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Uniqueness is enforced APP-LEVEL via the single write choke point
  // (src/lib/permissions/grant-repository.ts) — "one row per logical slot"
  // (tenant_id, role, role_id, resource, action, scope_type). The old
  // @@unique([role,resource,action,scopeType]) was DROPPED in Fase 6a: it ignored
  // tenant_id and blocked per-org overrides. A DB partial/NULLS NOT DISTINCT unique
  // is intentionally NOT used (Prisma 7 can't model it → would drift, breaking the
  // empty-_probe invariant the auto-migrate relies on).
  @@index([tenantId])
  @@index([roleId])
  @@map("role_permissions")
}

// Custom, per-org role (R&P Fase 3). Tenant-scoped (Sub-19 pattern). Global templates
// are intentionally NOT modeled here — deferred to a future phase (see ADR note).
model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  key         String
