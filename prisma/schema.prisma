  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([pageId, sortOrder])
  @@map("landing_page_sections")
}

// ========================
// Meeting Enums
// ========================

enum MeetingType {
  VIRTUAL
  IN_PERSON
}

enum MeetingStatus {
  SCHEDULED
  RECORDING
  PROCESSING
  READY
  ERROR
}

enum MeetingPlatform {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  IN_PERSON
  OTHER
}

// ========================
// Meeting Models
// ========================

model Meeting {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?

  meetingType MeetingType
  platform    MeetingPlatform @default(IN_PERSON)
  status      MeetingStatus   @default(SCHEDULED)

  // Timing
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Float? // seconds

  // Audio / Recording
  audioFileUrl  String?
  audioFileSize Int?
  audioMimeType String?

  // Transcript
  transcript String? // speaker-diarized text
  chunkCount Int     @default(0)

  // AI-generated content
  summary     String?
  actionItems Json? // [{text, assignee?, dueDate?, completed}]
  keyTopics   String[]

  // Calendar link (for virtual meetings)
  calendarEventId String?
  meetingUrl      String? // join URL

  // External bot (Recall.ai)
  externalBotId String?

  // Participants
  participantCount Int?

  // Error handling
  errorMessage String?

  // Timestamps
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants MeetingParticipant[]

  @@index([status])
  @@index([meetingType])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("meetings")
}

model MeetingParticipant {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String @db.Uuid

  name         String
  email        String?
  speakerLabel String? // "Speaker 1" — mapped from diarization
  role         String? // "organizer" | "attendee"

  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_participants")
}

model MeetingAgentConfig {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  isEnabled Boolean @default(true)

  // Bot configuration
  botName       String @default("HERD Notetaker")
  autoJoin      Boolean @default(true)
  joinMinutesBefore Int @default(1)
  recordingMode String @default("audio_only") // audio_only | speaker_view | gallery_view

  // Processing pipeline
  autoTranscribe     Boolean @default(true)
  autoSummarize      Boolean @default(true)
  autoExtractActions Boolean @default(true)

  // Filtering rules — which meetings should the agent join?
  joinAllMeetings  Boolean  @default(true)
  includePlatforms String[] // empty = all platforms
  excludeKeywords  String[] // skip meetings with these words in title
  includeKeywords  String[] // only join meetings with these words (if non-empty)
  minimumAttendees Int      @default(0) // skip small meetings if set > 0

  // Output preferences
  generateNextSteps   Boolean @default(true)
  generateSuggestions Boolean @default(false)
  notifyOnCompletion  Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meeting_agent_config")
}

// ========================
// Calendar Source & Status Enums
// ========================

enum CalendarSource {
  GOOGLE_CALENDAR
  OUTLOOK
  ICAL
}

enum EventSyncStatus {
  SYNCED
  STALE
  ERROR
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

// ========================
// Calendar Event Models
// ========================

model CalendarEventSync {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source             CalendarSource
  externalCalendarId String
  calendarName       String
  calendarColor      String?
  timeZone           String?
  isActive           Boolean        @default(true)

  // Link to Integration (nullable for future non-integration calendars)
  integrationId String? @db.Uuid

  // Sync metadata
  lastSyncAt    DateTime?
  lastSyncError String?
  syncToken     String? // Google Calendar incremental sync token

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events CalendarEvent[]

  @@unique([source, externalCalendarId])
  @@map("calendar_event_syncs")
}

model CalendarEvent {
  id              String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  calendarSyncId  String @db.Uuid
  externalEventId String

  title       String
  description String?
  location    String?

  startAt  DateTime
  endAt    DateTime
  isAllDay Boolean @default(false)
  timeZone String?

  status     EventStatus     @default(CONFIRMED)
  syncStatus EventSyncStatus @default(SYNCED)

  htmlLink       String?
  meetingUrl     String?
  conferenceData Json?

  recurrence       String[]
  recurringEventId String?

  organizerEmail String?
  organizerName  String?

  visibility   String? // "default", "public", "private", "confidential"
  transparency String? // "opaque", "transparent"
  colorId      String?

  lastSyncedAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendees    CalendarEventAttendee[]
  calendarSync CalendarEventSync       @relation(fields: [calendarSyncId], references: [id], onDelete: Cascade)

  @@unique([calendarSyncId, externalEventId])
  @@index([startAt])
  @@index([endAt])
  @@index([status])
  @@index([calendarSyncId])
  @@map("calendar_events")
}

model CalendarEventAttendee {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId String @db.Uuid

  email          String
  displayName    String?
  responseStatus String // "needsAction", "declined", "tentative", "accepted"
  isOrganizer    Boolean @default(false)
  isSelf         Boolean @default(false)

  createdAt DateTime @default(now())

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([email])
  @@map("calendar_event_attendees")
}

// ========================
// Tasks
// ========================

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  description       String?
  status            TaskStatus   @default(TODO)
  priority          TaskPriority @default(NONE)
  dueDate           DateTime?
  assignee          String?
  assigneeEmail     String?
  projectName       String?
  labels            String[]
  sourceIntegration String?
  sourceId          String?
  sourceUrl         String?
  sourceStatus      String?
  sourcePriority    String?
  parentTaskId      String?      @db.Uuid
  completedAt       DateTime?
  rawData           Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  parent   Task?  @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children Task[] @relation("TaskSubtasks")

  @@unique([sourceIntegration, sourceId])
  @@index([status])
  @@index([dueDate])
  @@index([sourceIntegration])
  @@map("tasks")
}
