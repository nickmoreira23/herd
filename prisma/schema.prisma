enum MeetingType {
  VIRTUAL
  IN_PERSON
}

enum MeetingStatus {
  SCHEDULED
  RECORDING
  PROCESSING
  READY
  ERROR
}

enum MeetingPlatform {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  IN_PERSON
  OTHER
}

// ========================
// Meeting Models
// ========================

model Meeting {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?

  meetingType MeetingType
  platform    MeetingPlatform @default(IN_PERSON)
  status      MeetingStatus   @default(SCHEDULED)

  // Timing
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Float? // seconds

  // Audio / Recording
  audioFileUrl  String?
  audioFileSize Int?
  audioMimeType String?

  // Transcript
  transcript String? // speaker-diarized text
  chunkCount Int     @default(0)

  // AI-generated content
  summary     String?
  actionItems Json? // [{text, assignee?, dueDate?, completed}]
  keyTopics   String[]

  // Calendar link (for virtual meetings)
  calendarEventId String?
  meetingUrl      String? // join URL

  // External bot (Recall.ai)
  externalBotId String?

  // Participants
  participantCount Int?

  // Error handling
  // - errorMessage: fatal pipeline failure → status flips to ERROR.
  // - summaryError: partial failure of the optional summarize step;
  //   transcript still landed, Meeting stays READY. See AGENTS.md
  //   "Recall integration — divergência arquitetural consciente".
  errorMessage String?
  summaryError String?

  // Timestamps
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  participants MeetingParticipant[]

  @@index([status])
  @@index([meetingType])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("meetings")
}

model MeetingParticipant {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String @db.Uuid

  name         String
  email        String?
  speakerLabel String? // "Speaker 1" — mapped from diarization
  role         String? // "organizer" | "attendee"

  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_participants")
}

model MeetingAgentConfig {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  isEnabled Boolean @default(true)

  // Bot configuration
  botName           String  @default("HERD Notetaker")
  autoJoin          Boolean @default(true)
  joinMinutesBefore Int     @default(1)
  recordingMode     String  @default("audio_only") // audio_only | speaker_view | gallery_view

  // Processing pipeline
  autoTranscribe     Boolean @default(true)
  autoSummarize      Boolean @default(true)
  autoExtractActions Boolean @default(true)

  // Filtering rules — which meetings should the agent join?
  joinAllMeetings  Boolean  @default(true)
  includePlatforms String[] // empty = all platforms
  excludeKeywords  String[] // skip meetings with these words in title
  includeKeywords  String[] // only join meetings with these words (if non-empty)
  minimumAttendees Int      @default(0) // skip small meetings if set > 0

  // Output preferences
  generateNextSteps   Boolean @default(true)
  generateSuggestions Boolean @default(false)
  notifyOnCompletion  Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("meeting_agent_config")
}

