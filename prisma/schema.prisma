generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================
// Subscription Tier Enums
// ========================

enum SubscriptionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubscriptionVisibility {
  PUBLIC
  REP_ONLY
  HIDDEN
}

enum BillingAnchor {
  SIGNUP_DATE
  FIRST_OF_MONTH
}

enum CreditIssuingTiming {
  ON_PAYMENT
  FIXED_DATE
}

enum CreditExpiryBehavior {
  FORFEIT
  CONVERT
  DONATE
}

enum TierChangeTiming {
  IMMEDIATE
  NEXT_CYCLE
}

enum CreditOnChange {
  CARRY_OVER
  RESET
  FORFEIT_EXCESS
}

enum PauseCreditBehavior {
  FROZEN
  FORFEIT
}

enum CancelCreditBehavior {
  FORFEIT
  GRACE_PERIOD
  KEEP_FOREVER
}

// ========================
// AI Agent Enums
// ========================

enum AgentStatus {
  DRAFT
  ACTIVE
  BETA
  DEPRECATED
}

enum AgentCategory {
  NUTRITION
  TRAINING
  RECOVERY
  COACHING
  ANALYTICS
  IMAGE_GENERATION
  VIDEO_GENERATION
  VOICE
  MULTIMODAL
}

enum ModelType {
  TEXT
  IMAGE
  VIDEO
  VOICE
}

enum KnowledgeItemType {
  DOCUMENT
  URL
  TEXT
  FAQ
  API_REFERENCE
}

enum KnowledgeItemStatus {
  DRAFT
  PROCESSING
  ACTIVE
  ERROR
  ARCHIVED
}

enum AgentToolAuthType {
  NONE
  API_KEY
  OAUTH2
  BEARER_TOKEN
  CUSTOM_HEADER
}

enum AgentRole {
  ORCHESTRATOR
  SPECIALIST
  BLOCK
}

// ========================
// Landing Page Enums
// ========================

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ========================
// D2D Commission Enums
// ========================

// ========================
// Partner Brand Enums
// ========================

model Product {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  name           String
  sku            String
  category       String // SUPPLEMENT | APPAREL | ACCESSORY
  subCategory    String?
  redemptionType String  @default("Members Store") // "Members Store" | "Members Rate"
  retailPrice    Decimal @db.Decimal(10, 2)
  memberPrice    Decimal @db.Decimal(10, 2)
  costOfGoods    Decimal @db.Decimal(10, 2)

  // Cost components for advanced metrics
  shippingCost          Decimal  @default(0) @db.Decimal(10, 2)
  handlingCost          Decimal  @default(0) @db.Decimal(10, 2)
  paymentProcessingPct  Decimal  @default(0) @db.Decimal(5, 2) // e.g. 2.90 = 2.9%
  paymentProcessingFlat Decimal  @default(0) @db.Decimal(10, 2) // e.g. 0.30 flat fee
  mapPrice              Decimal? @db.Decimal(10, 2) // minimum advertised price

  imageUrl  String?
  isActive  Boolean  @default(true)
  weightOz  Decimal? @db.Decimal(8, 2)
  tags      String[] // PostgreSQL native string array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Extended product info (populated via URL scraping or manual entry)
  description          String?
  brand                String?
  sourceUrl            String? // URL this product was scraped from
  flavor               String? // Selected variant/flavor
  variants             Json? // [{name: "Flavor", options: ["Blue Raz", "Watermelon"]}]
  servingSize          String?
  servingsPerContainer Int?
  ingredients          String? // Plain text ingredient list
  supplementFacts      Json? // [{name, amount, unit, dailyValue}]
  warnings             String?

  // Scrape lifecycle
  scrapeStatus     String? // PENDING | PROCESSING | READY | ERROR
  scrapeError      String?
  lastScrapedAt    DateTime?
  rescrapeInterval String? // DAILY | WEEKLY | MONTHLY | null=off
  nextRescrapeAt   DateTime?

  images          ProductImage[]
  packageProducts PackageTierProduct[]

  // L1a — catalog detenanting. tenant_id NOT NULL + strict RLS (L1a.4).
  tenant Organization @relation("ProductTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // L1a.4 addendum — SKU is unique per tenant, not globally (0 collisions
  // verified in DEV/PROD before the swap).
  @@unique([tenantId, sku])
  @@index([tenantId])
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Agent {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  key             String        @unique
  description     String?
  longDescription String?
  category        AgentCategory
  icon            String        @default("bot")
  iconUrl         String?
  status          AgentStatus   @default(DRAFT)
  sortOrder       Int           @default(0)

  // AI/LLM Configuration
  modelType     ModelType @default(TEXT)
  modelProvider String?
  modelId       String?
  systemPrompt  String?
  temperature   Decimal?  @db.Decimal(3, 2)
  maxTokens     Int?

  // Image model config
  imageSize    String? // "1024x1024", "1792x1024", "1024x1792"
  imageStyle   String? // "natural", "vivid", "anime", etc.
  imageQuality String? // "standard", "hd"

  // Video model config
  videoDuration    Int? // max duration in seconds
  videoResolution  String? // "720p", "1080p", "4k"
  videoAspectRatio String? // "16:9", "9:16", "1:1"

  // Voice model config
  voiceId        String? // provider-specific voice identifier
  voiceSpeed     Decimal? @db.Decimal(3, 2) // 0.25 to 4.0
  voiceStability Decimal? @db.Decimal(3, 2) // 0.0 to 1.0

  // Rate Limiting & Cost
  dailyUsageLimit     Int?
  monthlyCostEstimate Decimal? @db.Decimal(10, 2)
  avgTokensPerCall    Int?

  // Feature flags
  requiresMedia    Boolean @default(false)
  requiresHealth   Boolean @default(false)
  isConversational Boolean @default(false)

  // Response format
  responseFormat String? // "text" | "json" | "structured"

  // Role & Scope
  role     AgentRole @default(BLOCK)
  scope    String?
  isSystem Boolean   @default(false)

  // Runtime behavior
  confirmationTier String  @default("none")
  autoNavigate     Boolean @default(false)
  historyWindow    Int     @default(30)

  // Multimodal capabilities
  acceptsImages            Boolean @default(false)
  acceptsAudio             Boolean @default(false)
  acceptsVideo             Boolean @default(false)
  acceptsDocuments         Boolean @default(false)
  canGenerateImages        Boolean @default(false)
  canGenerateAudio         Boolean @default(false)
  canGenerateVideo         Boolean @default(false)
  canGeneratePresentations Boolean @default(false)

  // Metadata
  version   String   @default("1.0")
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tierAccess     AgentTierAccess[]
  knowledgeItems AgentKnowledgeItem[]
  skills         AgentSkill[]
  tools          AgentTool[]
  conversations  ChatConversation[]
  routines       Routine[]
  routineSteps   RoutineStep[]
}

model AgentTierAccess {
  id                      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId                 String  @db.Uuid
  subscriptionTierId      String  @db.Uuid
  isEnabled               Boolean @default(true)
  dailyUsageLimitOverride Int?
  priorityAccess          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tier  SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)

  @@unique([agentId, subscriptionTierId])
}

model AgentKnowledgeItem {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId       String              @db.Uuid
  type          KnowledgeItemType
  title         String
  content       String?
  sourceUrl     String?
  fileKey       String?
  fileMimeType  String?
  fileSizeBytes Int?
  status        KnowledgeItemStatus @default(ACTIVE)
  metadata      Json?
  priority      Int                 @default(0)
  sortOrder     Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, title])
}

model AgentSkill {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId        String   @db.Uuid
  name           String
  key            String
  description    String?
  promptFragment String?
  isEnabled      Boolean  @default(true)
  requiresTools  String[]
  category       String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
}

model AgentTool {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentId            String            @db.Uuid
  name               String
  key                String
  description        String?
  toolSchema         Json?
  endpointUrl        String?
  httpMethod         String            @default("POST")
  authType           AgentToolAuthType @default(NONE)
  authConfig         Json?
  headers            Json?
  timeoutMs          Int               @default(30000)
  isEnabled          Boolean           @default(true)
  rateLimitPerMinute Int?
  sortOrder          Int               @default(0)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, key])
}

model SubscriptionTier {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  slug              String   @unique
  tagline           String?
  colorAccent       String   @default("#6B7280")
  iconUrl           String?
  description       String?
  highlightFeatures String[]
  sortOrder         Int      @default(0)

  // Status & visibility
  status     SubscriptionStatus     @default(ACTIVE)
  visibility SubscriptionVisibility @default(PUBLIC)
  isActive   Boolean                @default(true) // DEPRECATED — use status; kept for migration
  isFeatured Boolean                @default(false)

  // Pricing
  // Each rate represents the DISCOUNTED PER-MONTH price the customer pays
  // when committing to that billing cadence. The customer prepays the full
  // cycle: biannual = rate × 6 charged once every 6 months; annual = rate
  // × 12 charged once a year. Monthly is billed monthly with no discount.
  // "Quarterly" billing does not exist in this product.
  monthlyPrice    Decimal       @db.Decimal(10, 2)
  biannualPrice   Decimal       @db.Decimal(10, 2)
  annualPrice     Decimal       @db.Decimal(10, 2)
  biannualDisplay Decimal?      @db.Decimal(10, 2) // optional strikethrough price for marketing
  annualDisplay   Decimal?      @db.Decimal(10, 2) // optional strikethrough price for marketing
  setupFee        Decimal       @default(0) @db.Decimal(10, 2)
  trialDays       Int           @default(0)
  billingAnchor   BillingAnchor @default(SIGNUP_DATE)

  // Per-subscriber average costs — drive package profitability calc
  avgShippingCost   Decimal @default(0) @db.Decimal(10, 2)
  avgHandlingCost   Decimal @default(0) @db.Decimal(10, 2)
  processingFeePct  Decimal @default(0) @db.Decimal(10, 2) // e.g. 2.90 = 2.9%
  processingFeeFlat Decimal @default(0) @db.Decimal(10, 2)

  // Credits
  monthlyCredits       Decimal              @db.Decimal(10, 2)
  creditExpirationDays Int                  @default(60)
  creditIssuing        CreditIssuingTiming  @default(ON_PAYMENT)
  rolloverMonths       Int                  @default(0) // 0 = no rollover
  rolloverCap          Decimal?             @db.Decimal(10, 2) // null = uncapped
  creditExpiry         CreditExpiryBehavior @default(FORFEIT)
  annualBonusCredits   Decimal              @default(0) @db.Decimal(10, 2)
  referralCreditAmt    Decimal              @default(0) @db.Decimal(10, 2)

  // Partner & apparel (existing)
  partnerDiscountPercent Decimal  @db.Decimal(5, 2)
  includedAIFeatures     String[]
  apparelCadence         String // NONE | QUARTERLY | MONTHLY
  apparelBudget          Decimal? @db.Decimal(10, 2)

  // Access controls
  maxMembers     Int? // null = unlimited
  geoRestriction String[] // ISO country codes, empty = all
  minimumAge     Int?
  inviteOnly     Boolean  @default(false)
  repChannelOnly Boolean  @default(false)

  // Tier movement
  upgradeToTierIds   String[] // cuid references to eligible upgrade targets
  downgradeToTierIds String[] // cuid references to eligible downgrade targets
  upgradeTiming      TierChangeTiming @default(IMMEDIATE)
  downgradeTiming    TierChangeTiming @default(NEXT_CYCLE)
  creditOnUpgrade    CreditOnChange   @default(CARRY_OVER)
  creditOnDowngrade  CreditOnChange   @default(FORFEIT_EXCESS)

  // Cancellation & retention
  minimumCommitMonths   Int                  @default(1)
  pauseAllowed          Boolean              @default(false)
  pauseMaxMonths        Int                  @default(0)
  pauseCreditBehavior   PauseCreditBehavior  @default(FROZEN)
  cancelCreditBehavior  CancelCreditBehavior @default(FORFEIT)
  cancelCreditGraceDays Int                  @default(0) // only used when cancelCreditBehavior = GRACE_PERIOD
  winbackDays           Int                  @default(0) // 0 = no win-back
  winbackBonusCredits   Decimal              @default(0) @db.Decimal(10, 2)
  exitSurveyRequired    Boolean              @default(false)

  // Value pillar JSON configs
  agentConfig     Json? // Tab 7: AI agent toggles
  communityConfig Json? // Tab 9: community benefits toggles
  perksConfig     Json? // Tab 10: perks toggles + sub-config

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  financialSnapshots   FinancialSnapshot[]
  redemptionRules      SubscriptionRedemptionRule[]
  pricingSnapshots     TierPricingSnapshot[]
  agentAccess          AgentTierAccess[]
  perkAssignments      PerkTierAssignment[]
  communityAssignments CommunityBenefitTierAssignment[]
  integrationMappings  IntegrationTierMapping[]
  packageVariants      PackageTierVariant[]
  // Sub-etapa 9 — Subscription rows reference SubscriptionTier as the
  // catalog plan they belong to (nullable; SET NULL on tier deletion).
  subscriptions        Subscription[]                   @relation("SubscriptionTier")
}

// @deprecated — replaced by CommissionPlan. Kept for migration.

