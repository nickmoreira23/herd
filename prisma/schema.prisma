  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant          Organization     @relation("RoleTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  membershipRoles MembershipRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

