  completedAt  DateTime?
  durationMs   Int?

  input      Json    @default("{}")
  output     String? @db.Text
  outputJson Json?
  error      String? @db.Text

  promptTokens     Int?
  completionTokens Int?

  // Per-step trace for multi-step routines.
  // Array of { stepId, stepOrder, status, output, outputJson, error,
  //            durationMs, promptTokens, completionTokens, startedAt, completedAt }.
