// ========================
// Admin Users — REMOVED (unified into NetworkProfile)
// AdminUser has been replaced by NetworkProfile.
// All users (including admins) are now NetworkProfile records
// with a profile type (e.g. "Administrator") and roles assigned
// via the NetworkRole RBAC system.
// ========================

// ========================
// Integrations
// ========================

enum IntegrationCategory {
  BILLING
  PAYMENT
  CRM
  ANALYTICS
  MARKETING
  COMMUNICATION
  SUPPORT
  MEETINGS
  PROJECT_MANAGEMENT
  SOCIAL_MEDIA
  AI_MODELS
  VOICE
  VIDEO
  NOTIFICATIONS
  OTHER
}

enum IntegrationStatus {
  AVAILABLE
  CONNECTED
  ERROR
  DISABLED
}

enum SyncDirection {
  INCOMING
  OUTGOING
  BIDIRECTIONAL
}

model Integration {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String?             @map("tenant_id") @db.Uuid
  name          String
  slug          String              @unique
  description   String?
  logoUrl       String?
  category      IntegrationCategory
  status        IntegrationStatus   @default(AVAILABLE)
  websiteUrl    String?
  docsUrl       String?
  credentials   String? // Encrypted JSON blob — admin/platform-level API keys, client_id/client_secret
  configJson    String? // Integration-specific config as JSON
  authType      String? // "token" | "oauth2" | "basic" — how members connect
  oauthScopes   String[] // OAuth scopes required for member connections (e.g. ["calendar.readonly"])
  connectedAt   DateTime?
  lastSyncAt    DateTime?
  lastSyncError String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tierMappings      IntegrationTierMapping[]
  webhookEvents     IntegrationWebhookEvent[]
  syncLogs          IntegrationSyncLog[]
  memberConnections MemberConnection[]
  messageChannels   MessageChannel[]
  voiceJobs         VoiceJob[]
  videoJobs         VideoJob[]
}

// Per-member connection to an integration (OAuth tokens, user-level auth)
// Admin sets up the platform credentials (client_id/secret) in Integration.credentials
// Members connect via OAuth flow and their personal tokens are stored here
model MemberConnection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  profileId      String    @db.Uuid
  integrationId  String    @db.Uuid
  status         String    @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED
  accessToken    String? // Encrypted
  refreshToken   String? // Encrypted
  tokenExpiresAt DateTime?
  externalUserId String? // User's ID in the external system
  externalEmail  String? // User's email in the external system
  scopes         String[] // Granted OAuth scopes
  metadata       Json? // Additional connection-specific data
  connectedAt    DateTime  @default(now())
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile     NetworkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  integration Integration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant      Organization   @relation("MemberConnectionTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  // Sub-etapa 9 — link from BillingCustomer (SET NULL on member disconnect).
  billingCustomers BillingCustomer[] @relation("BillingCustomerMemberConnection")

  @@unique([profileId, integrationId])
  @@index([integrationId])
  @@index([tenantId])
  @@map("member_connections")
}

model IntegrationTierMapping {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  integrationId      String        @db.Uuid
  externalPlanId     String
  externalPlanName   String?
  subscriptionTierId String        @db.Uuid
  syncDirection      SyncDirection @default(INCOMING)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  integration      Integration      @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  subscriptionTier SubscriptionTier @relation(fields: [subscriptionTierId], references: [id], onDelete: Cascade)
  tenant           Organization     @relation("IntegrationTierMappingTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalPlanId])
  @@index([tenantId])
}

model IntegrationWebhookEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  integrationId String    @db.Uuid
  eventType     String
  payload       String // Raw JSON
  processedAt   DateTime?
  error         String?
  createdAt     DateTime  @default(now())

  integration Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant      Organization @relation("IntegrationWebhookEventTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([eventType])
  @@index([tenantId])
}

model IntegrationSyncLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  integrationId    String   @db.Uuid
  action           String // e.g. "sync_plans", "test_connection"
  status           String // "success" | "error"
  details          String?
  recordsProcessed Int      @default(0)
  createdAt        DateTime @default(now())

  integration Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant      Organization @relation("IntegrationSyncLogTenant", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([tenantId])
}

