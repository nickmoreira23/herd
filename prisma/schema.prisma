  sectionType String   // "hero" | "features" | "testimonials" | "cta" | "custom" | etc.
  name        String?

  // Layout configuration
  layout     Json     @default("{}")  // { columns, gap, padding, alignment, maxWidth, background }

  // Components within this section (ordered array of component objects)
  components Json     @default("[]") // [{ id, type, props, styles, children? }]

  // Visibility & ordering
  isVisible  Boolean  @default(true)
  isLocked   Boolean  @default(false)
  sortOrder  Int      @default(0)

