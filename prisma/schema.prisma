}

enum PackageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Package {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String        @unique
  fitnessGoal            FitnessGoal
  customGoalDescription  String?
  description            String?
  imageUrl    String?
  status      PackageStatus @default(DRAFT)
  sortOrder   Int           @default(0)
